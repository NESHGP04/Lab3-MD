    "    stat, p_value = stats.shapiro(muestra)\n",
    "    resultado = \"Normal\" if p_value > 0.05 else \"No Normal\"\n",
    "    print(f\"{col:20s} | W={stat:.4f} | p-value={p_value:.6f} | {resultado}\")"
