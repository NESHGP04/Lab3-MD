    "    'Porcentaje (%)': porcentaje_nulos[porcentaje_nulos > 0]\n",
    "}).sort_values('Porcentaje (%)', ascending=False)\n",
    "\n",
    "print(f\"Columnas con valores nulos: {len(nulos_df)} de {datos.shape[1]}\")\n",
    "nulos_df"
